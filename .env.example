# Training
TRAIN_MODEL=efficientnet_b0
TRAIN_IMAGE_SIZE=224
TRAIN_BATCH_SIZE=32
TRAIN_EPOCHS=15
TRAIN_LR=0.0003
TRAIN_WEIGHT_DECAY=0.0001
TRAIN_NUM_WORKERS=2
TRAIN_PATIENCE=4
TRAIN_SEED=42
TRAIN_OUTPUT_DIR=runs/default
TRAIN_DATA_ROOT=
TRAIN_TRAIN_CSV=data/splits/train_clean.csv
TRAIN_VAL_CSV=data/splits/val_clean.csv
TRAIN_TEST_CSV=data/splits/test_clean.csv
TRAIN_PROVISIONAL_TRAIN_CSV=data/splits/train.csv
TRAIN_PROVISIONAL_VAL_CSV=data/splits/val.csv
TRAIN_PROVISIONAL_TEST_CSV=data/splits/test.csv
TRAIN_ALLOW_PROVISIONAL_DATA=false
TRAIN_RUN_TEST_AFTER_TRAINING=false

# RAG
ARTICLE_DATASET_PATH=data/articles/eye_conditions_open_access_database.json
CHROMA_DIR=data/articles/chroma
CHROMA_COLLECTION=medical_articles
EMBED_MODEL_NAME=pritamdeka/S-PubMedBert-MS-MARCO
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0.1
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_EMBED_BATCH_SIZE=16
RAG_TOP_K=5
RAG_CANDIDATE_MULTIPLIER=5
RAG_EXCLUDE_LOW_TRUST=true
RAG_EXCLUDED_TRUST_LEVELS=low

# Demo API
MODEL_ARTIFACT_SOURCE_URL=
MODEL_ARTIFACT_LOCAL_DIR=data/model_artifacts
MODEL_ARTIFACT_FORCE_REFRESH=false
MODEL_ARTIFACT_RUN_SUBDIR=
CLASSIFIER_DEVICE=cpu
CLASSIFIER_LOW_CONF_THRESHOLD=0.55
CLASSIFIER_TOP_K=3
APP_RAG_TOP_K=3
APP_TITLE=Retinal Image + RAG Demo
API_HOST=127.0.0.1
API_PORT=8001

# Frontend
DEMO_API_URL=http://127.0.0.1:8001
